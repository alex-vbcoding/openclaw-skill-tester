<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpenClaw Skill Tester</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      min-height: 100vh;
      padding: 20px;
      color: #1a202c;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
      color: #1a202c;
    }
    .tagline {
      color: #666;
      margin-bottom: 40px;
      font-size: 1.1rem;
    }
    .upload-section {
      background: #fafafa;
      padding: 30px;
      border-radius: 8px;
      margin-bottom: 40px;
      border: 1px solid #e2e8f0;
    }
    .upload-area {
      border: 2px dashed #cbd5e0;
      border-radius: 8px;
      padding: 60px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s;
    }
    .upload-area:hover {
      border-color: #4a5568;
      background: #f7fafc;
    }
    input[type="file"] { display: none; }
    .btn {
      background: #1a202c;
      color: white;
      border: none;
      padding: 12px 32px;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn:hover { background: #2d3748; }
    .section {
      margin-bottom: 40px;
    }
    .section h2 {
      font-size: 1.8rem;
      margin-bottom: 20px;
      color: #2d3748;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
    }
    th {
      background: #f7fafc;
      font-weight: 600;
      color: #4a5568;
    }
    .score {
      font-weight: bold;
      font-size: 1.2rem;
    }
    .score.high { color: #38a169; }
    .score.med { color: #d69e2e; }
    .score.low { color: #e53e3e; }
    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 0.85rem;
      font-weight: 600;
    }
    .badge.pass { background: #c6f6d5; color: #22543d; }
    .badge.fail { background: #fed7d7; color: #742a2a; }
  </style>
</head>
<body>
  <div class="container">
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:20px;">
      <div>
        <h1 style="margin-bottom:5px;">🦞 OpenClaw Skill Tester</h1>
        <p class="tagline" style="margin:0;">
          <% if (simple) { %>
            Upload your skill directory and get instant quality analysis
          <% } else { %>
            Test and validate OpenClaw skills - quality scoring, security checks, and performance benchmarks
          <% } %>
        </p>
      </div>
    </div>
    
    <div style="background:#fafafa;padding:20px;border-radius:6px;margin-bottom:30px;border-left:3px solid #1a202c;">
      <p style="margin:0;color:#4a5568;">
        <strong>What are OpenClaw Skills?</strong> 
        <a href="https://github.com/openclaw/openclaw" target="_blank" style="color:#1a202c;text-decoration:underline;">OpenClaw</a> 
        is a personal AI assistant that uses modular skills to extend its capabilities. 
        Skills are npm packages that give OpenClaw new abilities - from weather checks to home automation.
        <br><br>
        This tool helps developers ensure their skills meet quality standards before publishing.
      </p>
    </div>

    <div class="upload-section">
      <h2>Test Your Skill</h2>
      <div class="upload-area" onclick="document.getElementById('fileInput').click()">
        <p>📦 Drop your skill directory here or click to browse</p>
        <input type="file" id="fileInput" webkitdirectory directory multiple>
      </div>
      <div id="result" style="margin-top: 20px;"></div>
    </div>

    <% if (!simple) { %>
    <div class="section">
      <h2>🏆 Top Skills</h2>
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Skill</th>
            <th>Best Score</th>
            <th>Avg Score</th>
            <th>Tests</th>
          </tr>
        </thead>
        <tbody>
          <% topSkills.forEach((skill, i) => { %>
            <tr>
              <td>#<%= i + 1 %></td>
              <td><strong><%= skill.skillName %></strong></td>
              <td>
                <span class="score <%= skill.bestScore >= 90 ? 'high' : skill.bestScore >= 70 ? 'med' : 'low' %>">
                  <%= skill.bestScore %>/100
                </span>
              </td>
              <td><%= Math.round(skill.avgScore) %></td>
              <td><%= skill.testCount %></td>
            </tr>
          <% }); %>
          <% if (topSkills.length === 0) { %>
            <tr><td colspan="5" style="text-align:center;color:#999;">No skills tested yet. Be the first!</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

    <% if (!simple) { %>
    <div class="section">
      <h2>📊 Recent Tests</h2>
      <table>
        <thead>
          <tr>
            <th>Skill</th>
            <th>Score</th>
            <th>Status</th>
            <th>Tested</th>
          </tr>
        </thead>
        <tbody>
          <% recentTests.forEach(test => { %>
            <tr>
              <td><strong><%= test.skillName %></strong></td>
              <td>
                <span class="score <%= test.score >= 90 ? 'high' : test.score >= 70 ? 'med' : 'low' %>">
                  <%= test.score %>/100
                </span>
              </td>
              <td>
                <span class="badge <%= test.passed ? 'pass' : 'fail' %>">
                  <%= test.passed ? 'PASSED' : 'FAILED' %>
                </span>
              </td>
              <td><%= new Date(test.timestamp).toLocaleString() %></td>
            </tr>
          <% }); %>
          <% if (recentTests.length === 0) { %>
            <tr><td colspan="4" style="text-align:center;color:#999;">No recent tests</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% } %>

    <div style="text-align:center;margin-top:40px;color:#718096;font-size:0.9rem;">
      <p>
        Made for the <a href="https://github.com/openclaw/openclaw" target="_blank" style="color:#1a202c;">OpenClaw</a> community
        • Open source on <a href="https://github.com/alex-vbcoding/openclaw-skill-tester" target="_blank" style="color:#1a202c;">GitHub</a>
        <br>
        CLI: <code style="background:#f7fafc;padding:4px 8px;border-radius:4px;border:1px solid #e2e8f0;">npm install -g openclaw-skill-tester</code>
      </p>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
